---
const { shape = 'horizontal', slot = 'YOUR_HORIZONTAL_SLOT' } = Astro.props;
const heights = { horizontal: 120, square: 280, vertical: 600 };
const minHeight = heights[shape] || 120;
---
<div class="no-print">
  <div class="ad-label">Advertisement</div>
  <div class="ad-shell" style={`min-height:${minHeight}px`}>
    <ins class="adsbygoogle"
      style="display:block;width:100%"
      data-ad-client="ca-pub-3257080821006753"
      data-ad-slot={slot}
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
  </div>
</div>
<script is:inline>
  if (typeof window !== 'undefined') {
    window.adsbygoogle = window.adsbygoogle || [];
    try { window.adsbygoogle.push({}); } catch (e) {}
  }
</script>
