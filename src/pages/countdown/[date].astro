---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
export async function getStaticPaths() {
  return [
    { params: { date: '2026-12-25' } },
    { params: { date: '2027-01-01' } },
    { params: { date: '2026-10-31' } },
    { params: { date: '2026-04-25' } }
  ];
}
const { date } = Astro.params;
const target = `${date}T00:00:00`;
---
<BaseLayout title={`Countdown to ${date} | MyCalendarTools`} description={`Live countdown page for ${date} with share buttons and embeddable widget code.`}>
  <div class="hero">
    <div class="breadcrumbs"><a href="/">Home</a> / <span>Countdown</span> / <span>{date}</span></div>
    <h1>⏳ Countdown to {date}</h1>
    <p>Share this countdown, embed it on another site, or keep it bookmarked for a live timer.</p>
  </div>
  <div class="card">
    <div class="countdown" id="countdownGrid">
      <div class="unit"><div class="num">--</div><div>Days</div></div>
      <div class="unit"><div class="num">--</div><div>Hours</div></div>
      <div class="unit"><div class="num">--</div><div>Minutes</div></div>
      <div class="unit"><div class="num">--</div><div>Seconds</div></div>
    </div>
    <div class="grid grid-2" style="margin-top:20px">
      <div class="muted-box">
        <strong>Embed widget code</strong>
        <pre style="white-space:pre-wrap;color:#dfe4ff"><code>&lt;iframe src="https://www.mycalendartools.net/countdown/{date}" width="100%" height="320" style="border:0;border-radius:18px;"&gt;&lt;/iframe&gt;</code></pre>
      </div>
      <div class="muted-box">
        <strong>Share this countdown</strong>
        <div style="margin-top:10px"><ShareButtons url={Astro.url.href} title={`Countdown to ${date}`} /></div>
      </div>
    </div>
  </div>
  <script is:inline define:vars={{ target }}>
    const grid = document.getElementById('countdownGrid');
    function tick(){
      const diff = new Date(target).getTime() - Date.now();
      const days = Math.max(0, Math.floor(diff / 86400000));
      const hours = Math.max(0, Math.floor((diff % 86400000) / 3600000));
      const minutes = Math.max(0, Math.floor((diff % 3600000) / 60000));
      const seconds = Math.max(0, Math.floor((diff % 60000) / 1000));
      grid.innerHTML = `
        <div class="unit"><div class="num">${days}</div><div>Days</div></div>
        <div class="unit"><div class="num">${hours}</div><div>Hours</div></div>
        <div class="unit"><div class="num">${minutes}</div><div>Minutes</div></div>
        <div class="unit"><div class="num">${seconds}</div><div>Seconds</div></div>`;
    }
    tick();
    setInterval(tick,1000);
  </script>
</BaseLayout>
