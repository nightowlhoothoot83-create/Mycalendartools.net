---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSection from '../components/AdSection.astro';
---
<BaseLayout title="Days Between Dates Calculator | MyCalendarTools" description="Find days between any two dates, optionally excluding weekends, with moon phase and zodiac comparison.">
  <div class="hero">
    <div class="breadcrumbs"><a href="/">Home</a> / <span>Days Between</span></div>
    <h1>📆 Days Between Dates</h1>
    <p>Count total days, convert them into weeks plus days, exclude weekends if you need a workday-friendly result, and compare moon phases and zodiac signs for both dates.</p>
  </div>
  <div class="sidebar-layout">
    <div class="card">
      <div class="grid grid-2">
        <div class="field"><label for="startDate">Start date</label><input type="date" id="startDate" /></div>
        <div class="field"><label for="endDate">End date</label><input type="date" id="endDate" /></div>
      </div>
      <div class="field"><label><input type="checkbox" id="excludeWeekends" style="width:auto;margin-right:8px"/> Exclude weekends</label></div>
      <button class="btn" id="betweenBtn">Calculate</button>
      <div id="betweenResult" class="result"></div>
    </div>
    <AdSection shape="square" slot="YOUR_SQUARE_SLOT" />
  </div>
  <script is:inline>
    const s = document.getElementById('startDate');
    const e = document.getElementById('endDate');
    const res = document.getElementById('betweenResult');
    const today = new Date();
    const xmas = new Date(today.getFullYear(),11,25);
    s.value = today.toISOString().slice(0,10);
    e.value = xmas.toISOString().slice(0,10);
    function moonDataLite(d){
      const known = new Date('2000-01-06T18:14:00Z');
      const syn = 29.53058867;
      const cycle = ((((new Date(d)) - known)/86400000) % syn + syn) % syn;
      const phases = ['New Moon','Waxing Crescent','First Quarter','Waxing Gibbous','Full Moon','Waning Gibbous','Last Quarter','Waning Crescent'];
      return phases[Math.floor((cycle / syn) * 8) % 8];
    }
    function zodiacLite(d){
      const date = new Date(d), m = date.getMonth()+1, day = date.getDate();
      if((m===3&&day>=21)||(m===4&&day<=19)) return 'Aries';
      if((m===4&&day>=20)||(m===5&&day<=20)) return 'Taurus';
      if((m===5&&day>=21)||(m===6&&day<=20)) return 'Gemini';
      if((m===6&&day>=21)||(m===7&&day<=22)) return 'Cancer';
      if((m===7&&day>=23)||(m===8&&day<=22)) return 'Leo';
      if((m===8&&day>=23)||(m===9&&day<=22)) return 'Virgo';
      if((m===9&&day>=23)||(m===10&&day<=22)) return 'Libra';
      if((m===10&&day>=23)||(m===11&&day<=21)) return 'Scorpio';
      if((m===11&&day>=22)||(m===12&&day<=21)) return 'Sagittarius';
      if((m===12&&day>=22)||(m===1&&day<=19)) return 'Capricorn';
      if((m===1&&day>=20)||(m===2&&day<=18)) return 'Aquarius';
      return 'Pisces';
    }
    document.getElementById('betweenBtn').addEventListener('click', () => {
      const start = new Date(s.value);
      const end = new Date(e.value);
      if (Number.isNaN(start.getTime()) || Number.isNaN(end.getTime())) return;
      let days = Math.floor((end - start) / 86400000);
      if(document.getElementById('excludeWeekends').checked){
        let count = 0;
        const loop = new Date(start);
        while(loop < end){
          const wd = loop.getDay();
          if(wd !== 0 && wd !== 6) count++;
          loop.setDate(loop.getDate() + 1);
        }
        days = count;
      }
      const weeks = Math.floor(days / 7);
      const rem = days % 7;
      res.innerHTML = `
        <div class="mega">${days} days</div>
        <p>${weeks} weeks and ${rem} days</p>
        <div class="grid grid-2">
          <div class="muted-box"><strong>Start date</strong><br/>Moon: ${moonDataLite(s.value)}<br/>Zodiac: ${zodiacLite(s.value)}</div>
          <div class="muted-box"><strong>End date</strong><br/>Moon: ${moonDataLite(e.value)}<br/>Zodiac: ${zodiacLite(e.value)}</div>
        </div>`;
    });
    document.getElementById('betweenBtn').click();
  </script>
</BaseLayout>
