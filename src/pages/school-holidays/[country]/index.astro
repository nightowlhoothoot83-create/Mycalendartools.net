
---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import holidays from '../../../data/holidays.json';

export async function getStaticPaths() {
  return Object.keys(holidays.years['2026']).map((country) => ({ params: { country } }));
}
const { country } = Astro.params;
const years = ['2025','2026','2027'];
const countryName = holidays.years['2026'][country].name;
const regions = Object.entries(holidays.years['2026'][country].regions);
---
<BaseLayout title={`${countryName} School Holidays 2025-2027 | MyCalendarTools`} description={`Planning calendar pages for ${countryName} school holidays across multiple regions.`}>
  <div class="hero">
    <div class="breadcrumbs"><a href="/">Home</a> / <a href="/school-holidays">School Holidays</a> / <span>{countryName}</span></div>
    <h1>{countryName} School Holidays</h1>
    <p>Three years of region-level planning calendars for {countryName}, laid out in a clean format with generated pages and export-friendly data.</p>
    <div class="hero-meta">
      <span>{regions.length} regions</span>
      <span>2025, 2026, 2027</span>
      <span>Planning-friendly summaries</span>
    </div>
  </div>

  <section class="section grid">
    {years.map((year) => (
      <div class="card">
        <div class="section-head">
          <div>
            <h2>{year}</h2>
            <p>Use the generated region pages below for a cleaner drill-down by break and length.</p>
          </div>
          <a class="btn secondary" href={`/year-at-glance?country=${country}&year=${year}`}>Open year at a glance</a>
        </div>
        <div class="grid">
          {Object.entries(holidays.years[year][country].regions).map(([slug, region]) => (
            <div class="muted-box">
              <strong>{region.name}</strong>
              <ul class="list">
                {region.breaks.map((item) => <li>{item.name}: {item.start} → {item.end} ({item.days} days)</li>)}
              </ul>
              <p><a class="text-link" href={`/school-holidays/generated/${country}/${slug}/${year}`}>Open generated planning page →</a></p>
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>

  <section class="section grid grid-2">
    <div class="card">
      <h2>How to use these pages</h2>
      <p>Use the summaries here to compare years quickly, then open the generated region page for a more focused planning view. This is especially useful for families comparing travel windows, school returns, and childcare timing.</p>
    </div>
    <div class="card">
      <h2>Related tools</h2>
      <div class="related-links">
        <a href="/between">Days Between</a>
        <a href="/weeks">Weeks Between</a>
        <a href="/week-number">Week Number</a>
        <a href="/year-at-glance">Year at a Glance</a>
      </div>
    </div>
  </section>
</BaseLayout>
